BRIGHTDATA_WEB_SCRAPER_ZONE=""
BRIGHTDATA_SERP_ZONE=""
BRIGHTDATA_UNLOCKER_ZONE=""
BRIGHTDATA_SCRAPING_BROWSER_WS_URL=""

# Slack Webhook (Optional for output integrations)
SLACK_WEBHOOK_URL=""

# AIML API Configuration
AIML_API_KEY=""
